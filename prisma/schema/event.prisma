model Session {
    id                String  @id @default(uuid())
    sessionIdentifier String  @unique
    sessionNumber     Int
    year              String
    bucketFormat      SessionBucketFormat?
    isActive          Boolean @default(true)

    eventSessions EventSession[]
    eventResults  EventResult[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([year])
    @@map("sessions")
}

model Event {
    id                 String  @id @default(uuid())
    // ── Permanent Identity (Step 1) ───────────────────────────
    baseEventName      String?
    eventName          String
    eventYear          String?
    eventSessionLabel  String?
    coverImage         String
    programId          String
    program            Program @relation(fields: [programId], references: [id])
    organizer          String
    // Venue / area text for search & filters (e.g. "Dhaka, Bangladesh")
    location           String?
    eventPortal        String
    registrationPortal String
    description        String
    note               String?
    // ── Repeat Configuration ──────────────────────────────────
    repeatConfig RepeatConfig?
    // ── Session (One Event has one session detail row) ─────────
    eventSession EventSession?

    // ── Own history (optional; only rows when you add winners per Session)
    results EventResult[]

    applications EventApplication[]

    editLogs     EditLog[]
    version      Int       @default(1) // optimistic locking
    creatorId    String
    creator      User      @relation("EventCreator", fields: [creatorId], references: [id], onDelete: Restrict)
    lastEditorId String?
    lastEditor   User?     @relation("EventLastEditor", fields: [lastEditorId], references: [id], onDelete: SetNull)
    isPublished  Boolean   @default(true)
    /// Ops toggle: pause/hide from feeds without deleting (`deletedAt`). Still separate from `isPublished` (visibility).
    isActive     Boolean   @default(true)
    isLocked     Boolean   @default(false)
    deletedAt    DateTime? // soft delete

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([programId])
    @@index([eventName])
    @@index([creatorId])
    @@index([lastEditorId])
    @@map("events")
}

model EventSession {
    id String @id @default(uuid())
    eventId String @unique
    event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
    sessionId String
    session   Session @relation(fields: [sessionId], references: [id], onDelete: Restrict)

    // ── Session-Specific Details ─────────────────────────────
    competitionLevel CompetitionLevel
    eventType        EventType
    registrationDate DateTime
    deadline         DateTime
    cost             Decimal          @db.Decimal(10, 2)
    hasFinalDeadline Boolean          @default(false)
    finalDeadline    DateTime?
    lateFee          Decimal          @default(0) @db.Decimal(10, 2) // fixed amount; 0 = no late fee

    // ── Session State ─────────────────────────────────────────
    status                  SessionStatus @default(Unverified)
    isSharedToCommunity     Boolean       @default(false)
    isUserAgreementAccepted Boolean       @default(false)
    autoGenerated           Boolean       @default(false)
    isCurrentSession        Boolean       @default(false)
    groups                  EventGroup[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([sessionId])
    @@index([eventId, isCurrentSession])
    @@map("event_sessions")
}

model EventGroup {
    id String @id @default(uuid())
    eventSessionId String
    eventSession   EventSession @relation(fields: [eventSessionId], references: [id], onDelete: Cascade)
    name        String
    criteria    GroupCriteria
    condition   RoundCondition
    value       Int
    rounds EventRound[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([eventSessionId])
    @@map("event_groups")
}

model EventRound {
    id      String     @id @default(uuid())
    groupId String
    group   EventGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
    roundType        CompetitionLevel
    deadline         DateTime
    cost             Decimal          @db.Decimal(10, 2)
    hasFinalDeadline Boolean          @default(false)
    finalDeadline    DateTime?
    lateFee          Decimal          @default(0) @db.Decimal(10, 2) // fixed amount; 0 = no late fee
    description      String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([groupId])
    @@map("event_rounds")
}

model RepeatConfig {
    id      String @id @default(uuid())
    eventId String @unique
    event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
    frequency            RepeatFrequency @default(DontRepeat)
    startDate            DateTime?
    nextAutoGenerateDate DateTime?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("repeat_configs")
}

model EventResult {
    id String @id @default(uuid())
    eventId   String
    event     Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
    sessionId String
    session   Session @relation(fields: [sessionId], references: [id], onDelete: Restrict)

    placement PlacementType
    note      String?

    createdAt DateTime @default(now())

    @@unique([eventId, sessionId, placement])
    @@index([sessionId])
    @@map("event_results")
}

model EventApplication {
    id      String @id @default(uuid())
    eventId String
    event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
    userId  String
    user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    status EventApplicationStatus @default(Pending)
    note   String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([eventId, userId])
    @@index([userId])
    @@map("event_applications")
}

model EditLog {
    id      String @id @default(uuid())
    eventId String
    event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

    version        Int // which Event version this edit created
    editorId       String
    editor         User     @relation(fields: [editorId], references: [id], onDelete: Restrict)
    changedFields  String[]
    previousValues Json

    createdAt DateTime @default(now())

    @@index([eventId])
    @@index([createdAt])
    @@index([editorId])
    @@map("edit_logs")
}
