model Session {
    id                String  @id @default(uuid())
    sessionIdentifier String  @unique
    sessionNumber     Int
    year              String
    isActive          Boolean @default(true)

    eventSessions EventSession[]
    eventResults  EventResult[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([year])
    @@map("sessions")
}

model Event {
    id                 String  @id @default(uuid())
    // ── Permanent Identity (Step 1) ───────────────────────────
    eventName          String
    coverImage         String
    programId          String
    program            Program @relation(fields: [programId], references: [id])
    organizer          String
    eventPortal        String
    registrationPortal String
    description        String
    note               String?

    // ── Repeat Configuration ──────────────────────────────────
    repeatConfig RepeatConfig?

    // ── Sessions (Many-to-Many via EventSession) ──────────────
    eventSessions EventSession[]

    // ── Own history (optional; only rows when you add winners per Session)
    results EventResult[]

    // ── Wiki Meta ─────────────────────────────────────────────
    editLogs     EditLog[]
    version      Int       @default(1) // optimistic locking
    creatorId    String
    creator      User      @relation("EventCreator", fields: [creatorId], references: [id], onDelete: Restrict)
    lastEditorId String?
    lastEditor   User?     @relation("EventLastEditor", fields: [lastEditorId], references: [id], onDelete: SetNull)
    verifiedById String?
    verifiedBy   User?     @relation("EventVerifier", fields: [verifiedById], references: [id], onDelete: SetNull)
    verifiedAt   DateTime?
    isVerified   Boolean   @default(false)
    isPublished  Boolean   @default(true)
    isActive     Boolean   @default(true)
    isLocked     Boolean   @default(false)
    deletedAt    DateTime? // soft delete

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([programId])
    @@index([eventName])
    @@index([creatorId])
    @@index([lastEditorId])
    @@index([verifiedById])
    @@map("events")
}

model EventSession {
    id String @id @default(uuid())
    eventId String
    event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
    sessionId String
    session   Session @relation(fields: [sessionId], references: [id], onDelete: Restrict)

    // ── Session-Specific Details ─────────────────────────────
    competitionLevel CompetitionLevel
    eventType        EventType
    registrationDate DateTime
    deadline         DateTime
    cost             Decimal          @db.Decimal(10, 2)
    hasFinalDeadline Boolean          @default(false)
    finalDeadline    DateTime?
    lateFee          Decimal          @default(0) @db.Decimal(10, 2) // fixed amount; 0 = no late fee

    // ── Session State ─────────────────────────────────────────
    status                  SessionStatus @default(Draft)
    isSharedToCommunity     Boolean       @default(false)
    isUserAgreementAccepted Boolean       @default(false)
    autoGenerated           Boolean       @default(false)
    groups                  EventGroup[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // No duplicate session per event
    @@unique([eventId, sessionId])
    @@index([sessionId])
    @@map("event_sessions")
}

model EventGroup {
    id String @id @default(uuid())
    eventSessionId String
    eventSession   EventSession @relation(fields: [eventSessionId], references: [id], onDelete: Cascade)
    name        String
    criteria    GroupCriteria
    condition   RoundCondition
    value       Int

    rounds EventRound[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([eventSessionId])
    @@map("event_groups")
}

model EventRound {
    id      String     @id @default(uuid())
    groupId String
    group   EventGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

    roundType        CompetitionLevel
    deadline         DateTime
    cost             Decimal          @db.Decimal(10, 2)
    hasFinalDeadline Boolean          @default(false)
    finalDeadline    DateTime?
    lateFee          Decimal          @default(0) @db.Decimal(10, 2) // fixed amount; 0 = no late fee
    subjects         String[]
    description      String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([groupId])
    @@map("event_rounds")
}

model RepeatConfig {
    id      String @id @default(uuid())
    eventId String @unique
    event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

    // Single source of repeat behavior; DontRepeat = one-time event
    frequency            RepeatFrequency @default(DontRepeat)
    startDate            DateTime?
    interval             Int             @default(1)
    unit                 RepeatUnit?
    weekDays             WeekDay[]       @default([])
    monthDay             Int?
    monthWeek            MonthWeek?
    monthWeekDay         WeekDay?
    endType              RepeatEndType   @default(Never)
    endDate              DateTime?
    endAfterCount        Int?
    timezone             String?
    nextAutoGenerateDate DateTime?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("repeat_configs")
}

model EventResult {
    id String @id @default(uuid())

    // Own history: Session.id (not EventSession.id). Optional in practice — no rows until you add.
    eventId   String
    event     Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
    sessionId String
    session   Session @relation(fields: [sessionId], references: [id], onDelete: Restrict)

    placement PlacementType
    note      String?

    createdAt DateTime @default(now())

    @@unique([eventId, sessionId, placement])
    @@index([sessionId])
    @@map("event_results")
}

model EditLog {
    id      String @id @default(uuid())
    eventId String
    event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

    version        Int // which Event version this edit created
    editorId       String
    editor         User     @relation(fields: [editorId], references: [id], onDelete: Restrict)
    changedFields  String[]
    previousValues Json

    createdAt DateTime @default(now())

    @@index([eventId])
    @@index([createdAt])
    @@index([editorId])
    @@map("edit_logs")
}
