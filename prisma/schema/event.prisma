model Session {
    id                String        @id @default(uuid())
    sessionIdentifier String        @unique
    sessionNumber     Int
    year              String
    format            SessionFormat
    isActive          Boolean       @default(true)

    eventSessions EventSession[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([year])
    @@map("sessions")
}

model Event {
    id String @id @default(uuid())

    // ── Permanent Identity (Step 1) ───────────────────────────
    coverImage         String
    programId          String
    program            Program @relation(fields: [programId], references: [id])
    organizer          String
    eventName          String
    eventPortal        String
    registrationPortal String
    description        String
    note               String?

    // ── Repeat Configuration (Step 4) ────────────────────────
    repeatConfig RepeatConfig?

    // ── Sessions (Many-to-Many via EventSession) ──────────────
    eventSessions EventSession[]

    // ── Results (always under Event; eventSession optional = which occurrence) ──
    results EventResult[]

    // ── Wiki Meta ─────────────────────────────────────────────
    editLogs     EditLog[]
    version      Int       @default(1) // optimistic locking
    creatorId    String
    creator      User      @relation("EventCreator", fields: [creatorId], references: [id], onDelete: Restrict)
    lastEditorId String?
    lastEditor   User?     @relation("EventLastEditor", fields: [lastEditorId], references: [id], onDelete: SetNull)
    isPublished  Boolean   @default(false)
    isActive     Boolean   @default(true)
    isLocked     Boolean   @default(false)
    deletedAt    DateTime? // soft delete

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([programId])
    @@index([eventName])
    @@index([creatorId])
    @@index([lastEditorId])
    @@map("events")
}

model EventSession {
    id String @id @default(uuid())

    eventId String
    event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

    sessionId String
    session   Session @relation(fields: [sessionId], references: [id], onDelete: Restrict)

    // ── Session-Specific Details ─────────────────────────────
    competitionLevel   CompetitionLevel
    eventType          EventType
    registrationDate   DateTime
    deadline           DateTime
    cost               Decimal          @db.Decimal(10, 2)
    isHasFinalDeadline Boolean          @default(false)
    finalDeadline      DateTime?
    lateFeeValue       Decimal          @default(0) @db.Decimal(10, 2) // fixed amount; 0 = no late fee

    // ── Session State ─────────────────────────────────────────
    status                  SessionStatus @default(Draft)
    isSharedToCommunity     Boolean       @default(false)
    isUserAgreementAccepted Boolean       @default(false)
    autoGenerated           Boolean       @default(false)
    groups                  EventGroup[]

    results EventResult[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    program   Program? @relation(fields: [programId], references: [id])
    programId String?

    // No duplicate session per event
    @@unique([eventId, sessionId])
    @@index([eventId])
    @@index([sessionId])
    @@map("event_sessions")
}

model EventGroup {
    id String @id @default(uuid())

    eventSessionId String
    eventSession   EventSession @relation(fields: [eventSessionId], references: [id], onDelete: Cascade)

    name        String
    criteria    GroupCriteria
    condition   RoundCondition
    value       Int
    description String?
    tags        String[] @default([])

    rounds EventRound[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([eventSessionId])
    @@map("event_groups")
}

model EventRound {
    id      String     @id @default(uuid())
    groupId String
    group   EventGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

    roundType          CompetitionLevel
    eventType          EventType
    deadline           DateTime
    cost               Decimal          @db.Decimal(10, 2)
    isHasFinalDeadline Boolean          @default(false)
    finalDeadline      DateTime?
    lateFeeValue       Decimal          @default(0) @db.Decimal(10, 2) // fixed amount; 0 = no late fee
    subjects           String[]
    description        String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([groupId])
    @@map("event_rounds")
}

model RepeatConfig {
    id      String @id @default(uuid())
    eventId String @unique
    event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
    isRepeating          Boolean          @default(false)
    frequency            RepeatFrequency?
    sessionFormat        SessionFormat    @default(YYYY_QN)
    nextAutoGenerateDate DateTime?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("repeat_configs")
}

model EventResult {
    id      String @id @default(uuid())
    eventId String
    event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

    // Which run of this event (e.g. 2026-Q1); null = event-wide / not tied to one occurrence yet
    eventSessionId String?
    eventSession   EventSession? @relation(fields: [eventSessionId], references: [id], onDelete: Cascade)

    roundType CompetitionLevel
    placement PlacementType
    year      String
    note      String?

    createdAt DateTime @default(now())

    @@index([eventId])
    @@index([eventSessionId])
    @@map("event_results")
}

model EditLog {
    id      String @id @default(uuid())
    eventId String
    event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

    version        Int // which Event version this edit created
    editorId       String
    editor         User   @relation(fields: [editorId], references: [id], onDelete: Restrict)
    changedFields  String[]
    previousValues Json

    createdAt DateTime @default(now())

    @@index([eventId])
    @@index([createdAt])
    @@index([editorId])
    @@map("edit_logs")
}
