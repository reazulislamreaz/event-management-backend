generator client {
    provider = "prisma-client"
    output   = "../generated"
}

datasource db {
    provider = "postgresql"
}

// Enums
enum UserRole {
    ADMIN
    USER
}

enum UserStatus {
    ACTIVE
    BANNED
    DELETED
}

enum UserGender {
    MALE
    FEMALE
    OTHER
}

enum InvitationStatus {
    PENDING
    ACCEPTED
    DECLINED
    EXPIRED
}

enum FamilyRole {
    OWNER
    MEMBER
}

enum EventRepeatPattern {
    MONTHLY
    QUARTERLY
    YEARLY
    CUSTOM
    NULL
}

enum EventType {
    ONLINE
    OFFLINE
    HYBRID
}

enum EventStatus {
    UNVERIFIED
    VERIFIED
    CANCELED
    ACTIVE
    ENDED
}

// Models
model User {
    id                 String              @id @default(uuid())
    accountId          String              @unique
    firstName          String
    lastName           String
    username           String              @unique
    displayName        String?
    email              String              @unique
    password           String
    phoneNumber        String?
    gender             UserGender
    birthDate          DateTime
    profilePicture     String?             @default("https://areawins.s3.us-east-2.amazonaws.com/common/user.jpg")
    location           String
    country            String
    state              String
    city               String
    skills             String[]
    role               UserRole            @default(USER)
    status             UserStatus          @default(ACTIVE)
    isIndependent      Boolean             @default(false)
    isEmailVerified    Boolean             @default(false)
    createdByOwner     String?
    owner              User?               @relation("OwnerCreatedUsers", fields: [createdByOwner], references: [id], onDelete: SetNull)
    createdUsers       User[]              @relation("OwnerCreatedUsers")
    contributionScore  Int                 @default(0)
    createdAt          DateTime            @default(now())
    updatedAt          DateTime            @updatedAt
    families           Family[]            @relation("FamilyCreator")
    familyMembers      FamilyMember[]
    familyInvitations  FamilyInvitation[]  @relation("FamilyInvitedBy")
    familyJoinRequests FamilyJoinRequest[] @relation("FamilyJoinRequest")
    events             Event[]             @relation("EventCreator")
    editHistories      EditHistory[]

    @@index([createdByOwner])
    @@map("users")
}

// Category Model
model Category {
    id            String        @id @default(uuid())
    name          String        @unique
    imageUrl      String?
    description   String?
    isDeleted     Boolean       @default(false)
    createdAt     DateTime      @default(now())
    updatedAt     DateTime      @updatedAt
    subcategories Subcategory[]
    programs      Program[]

    @@map("categories")
}

// Create subcategory model with reference to category
model Subcategory {
    id          String    @id @default(uuid())
    categoryId  String
    name        String    @unique
    imageUrl    String?
    description String?
    isDeleted   Boolean   @default(false)
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt
    category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
    programs    Program[]

    @@index([categoryId])
    @@map("subcategories")
}

// Program model with reference category Or subcategory
model Program {
    id            String         @id @default(uuid())
    categoryId    String?
    subcategoryId String?
    name          String         @unique
    description   String?
    imageUrl      String?
    isDeleted     Boolean        @default(false)
    createdAt     DateTime       @default(now())
    updatedAt     DateTime       @updatedAt
    category      Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
    subcategory   Subcategory?   @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
    events        Event[]
    eventSessions EventSession[]

    @@index([categoryId])
    @@index([subcategoryId])
    @@map("programs")
}

// Family Model
model Family {
    id                 String              @id @default(uuid())
    name               String
    description        String?
    imageUrl           String?
    createdBy          String
    creator            User                @relation("FamilyCreator", fields: [createdBy], references: [id], onDelete: Restrict)
    isDeleted          Boolean             @default(false)
    createdAt          DateTime            @default(now())
    updatedAt          DateTime            @updatedAt
    familyMembers      FamilyMember[]
    familyInvitations  FamilyInvitation[]
    familyJoinRequests FamilyJoinRequest[]

    @@index([createdBy])
    @@map("families")
}

// FamilyMember Model
model FamilyMember {
    id           String     @id @default(uuid())
    familyId     String
    userId       String
    role         FamilyRole @default(MEMBER)
    relationShip String?
    family       Family     @relation(fields: [familyId], references: [id], onDelete: Cascade)
    user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
    createdAt    DateTime   @default(now())
    updatedAt    DateTime   @updatedAt

    @@unique([familyId, userId])
    @@index([familyId])
    @@index([userId])
    @@map("family_members")
}

// FamilyInvitation Model
model FamilyInvitation {
    id              String           @id @default(uuid())
    familyId        String
    invitedByUserId String
    invitedEmail    String
    family          Family           @relation(fields: [familyId], references: [id], onDelete: Cascade)
    invitedByUser   User             @relation("FamilyInvitedBy", fields: [invitedByUserId], references: [id], onDelete: Cascade)
    status          InvitationStatus @default(PENDING)
    createdAt       DateTime         @default(now())
    updatedAt       DateTime         @updatedAt

    @@unique([familyId, invitedEmail])
    @@index([familyId])
    @@index([invitedByUserId])
    @@map("family_invitations")
}

// FamilyJoinRequest Model
model FamilyJoinRequest {
    id        String           @id @default(uuid())
    familyId  String
    userId    String
    family    Family           @relation(fields: [familyId], references: [id], onDelete: Cascade)
    user      User             @relation("FamilyJoinRequest", fields: [userId], references: [id], onDelete: Cascade)
    status    InvitationStatus @default(PENDING)
    createdAt DateTime         @default(now())
    updatedAt DateTime         @updatedAt

    @@unique([familyId, userId])
    @@index([familyId])
    @@index([userId])
    @@map("family_join_requests")
}

// Event Model
model Event {
    id            String             @id @default(uuid())
    eventName     String
    createdBy     String
    creator       User               @relation("EventCreator", fields: [createdBy], references: [id], onDelete: Restrict)
    programId     String
    program       Program            @relation(fields: [programId], references: [id], onDelete: Cascade)
    repeatPattern EventRepeatPattern @default(NULL)
    createdAt     DateTime           @default(now())
    updatedAt     DateTime           @updatedAt
    isDeleted     Boolean            @default(false)
    eventSessions EventSession[]
    editHistories EditHistory[]
}

model OwnHistory {
    id             String        @id @default(uuid())
    session        String
    record         String[]
    eventSession   EventSession? @relation(fields: [eventSessionId], references: [id])
    eventSessionId String?

    @@map("own_histories")
}

model EventSession {
    // Step 1: Basic Information
    id                 String  @id @default(uuid())
    eventId            String
    sessionNumber      Int
    year               Int
    sessionLabel       String
    coverImageUrl      String?
    programId          String
    organizer          String?
    eventPortal        String?
    registrationPortal String?
    description        String?
    notes              String?
    program            Program @relation(fields: [programId], references: [id], onDelete: Cascade)
    event              Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)

    // Details
    competitionLevel     String?
    type                 EventType?
    registrationOpenDate DateTime?
    deadline             DateTime?
    cost                 Float?
    isHasFinalDeadline   Boolean?   @default(false)
    finalDeadline        DateTime?
    lateFee              String?
    location             String?

    // Own History + Checkboxes
    ownHistory       OwnHistory[]
    isShareCommunity Boolean      @default(true)
    isUserAgreement  Boolean      @default(true)
    status           EventStatus  @default(UNVERIFIED)
    createdAt        DateTime     @default(now())
    updatedAt        DateTime     @updatedAt
    eventGroups      EventGroup[]

    @@index([eventId])
    @@map("event_sessions")
}

// EventGroup
model EventGroup {
    id             String       @id @default(uuid())
    sessionId      String
    eventSession   EventSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
    category       String
    conditionType  String
    conditionValue Int
    groupLabel     String
    createdAt      DateTime     @default(now())
    updatedAt      DateTime     @updatedAt
    rounds         EventRound[]

    @@map("event_groups")
}

// EventRound
model EventRound {
    id                 String      @id @default(uuid())
    roundName          String
    deadline           DateTime
    cost               Float?
    isHasFinalDeadline Boolean?    @default(false)
    finalDeadline      DateTime?
    lateFee            String?
    type               String
    description        String?
    createdAt          DateTime    @default(now())
    updatedAt          DateTime    @updatedAt
    eventGroup         EventGroup? @relation(fields: [eventGroupId], references: [id])
    eventGroupId       String?

    @@map("event_rounds")
}

model EditHistory {
    id        String   @id @default(uuid())
    eventId   String
    editorId  String
    changes   String
    action    String //'created' | 'edited' | 'verified' | 'cancelled' | 'uncancelled'
    timestamp DateTime @default(now())
    event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
    editor    User     @relation(fields: [editorId], references: [id], onDelete: Cascade)

    @@map("edit_histories")
}
