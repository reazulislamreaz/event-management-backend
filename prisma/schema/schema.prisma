generator client {
    provider = "prisma-client"
    output   = "../generated"
}

datasource db {
    provider = "postgresql"
}

// Enums
enum UserRole {
    ADMIN
    USER
}

enum UserStatus {
    ACTIVE
    BANNED
    DELETED
}

enum NotificationType {
    INFO
    SUCCESS
    WARNING
    ERROR
}

// Models
model User {
    id                String         @id @default(uuid())
    accountId         String         @unique @default(cuid())
    firstName         String
    lastName          String
    username          String         @unique
    email             String         @unique
    password          String
    phoneNumber       String?
    gender            String?
    birthdate         DateTime?
    profilePicture    String?
    country           String?
    state             String?
    city              String?
    skills            String[]
    relationShip      String?
    role              UserRole       @default(USER)
    status            UserStatus     @default(ACTIVE)
    isIndependent     Boolean        @default(false)
    isEmailVerified   Boolean        @default(false)
    createdByOwner    String? // For tracking who created the user (if applicable)
    contributionScore Int            @default(0) // For tracking user contributions
    createdAt         DateTime       @default(now())
    updatedAt         DateTime       @updatedAt
    notifications     Notification[]

    @@map("users")
}

model Notification {
    id        String           @id @default(uuid())
    title     String
    message   String
    type      NotificationType
    read      Boolean          @default(false)
    createdAt DateTime         @default(now())
    updatedAt DateTime         @updatedAt
    userId    String

    // Relations
    user User @relation(fields: [userId], references: [id])

    @@map("notifications")
}
