generator client {
    provider = "prisma-client"
    output   = "../generated"
}

datasource db {
    provider = "postgresql"
}

// Enums
enum UserRole {
    ADMIN
    MANAGER
    USER
}

enum UserStatus {
    ACTIVE
    SUSPENDED
    BANNED
}

enum NotificationType {
    INFO
    SUCCESS
    WARNING
    ERROR
}

// Models
model User {
    id        String     @id @default(uuid())
    fullName  String
    email     String     @unique
    password  String
    status    UserStatus @default(ACTIVE)
    role      UserRole   @default(USER)
    createdAt DateTime   @default(now())
    updatedAt DateTime   @updatedAt

    // Relations
    notifications Notification[]

    @@map("users")
}

model Notification {
    id        String           @id @default(uuid())
    title     String
    message   String
    type      NotificationType
    read      Boolean          @default(false)
    createdAt DateTime         @default(now())
    updatedAt DateTime         @updatedAt
    userId    String

    // Relations
    user User @relation(fields: [userId], references: [id])

    @@map("notifications")
}
