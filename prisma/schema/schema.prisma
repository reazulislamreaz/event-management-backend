generator client {
    provider = "prisma-client"
    output   = "../generated"
}

datasource db {
    provider = "postgresql"
}

// Enums
enum UserRole {
    ADMIN
    USER
}

enum UserStatus {
    ACTIVE
    BANNED
    DELETED
}

enum UserGender {
    MALE
    FEMALE
    OTHER
}



// Models
model User {
    id                String     @id @default(uuid())
    accountId         String     @unique
    firstName         String
    lastName          String
    username          String     @unique
    email             String     @unique
    password          String
    phoneNumber       String?
    gender            UserGender
    birthDate         DateTime
    profilePicture    String?
    location          String
    country           String
    state             String
    city              String
    skills            String[]
    relationShip      String?
    role              UserRole   @default(USER)
    status            UserStatus @default(ACTIVE)
    isIndependent     Boolean    @default(false)
    isEmailVerified   Boolean    @default(false)
    createdByOwner    String?
    contributionScore Int        @default(0)
    createdAt         DateTime   @default(now())
    updatedAt         DateTime   @updatedAt

    @@map("users")
}
