generator client {
    provider = "prisma-client"
    output   = "../generated"
}

datasource db {
    provider = "postgresql"
}

// Enums
enum UserRole {
    ADMIN
    USER
}

enum UserStatus {
    ACTIVE
    BANNED
    DELETED
}

enum UserGender {
    MALE
    FEMALE
    OTHER
}

enum InvitationStatus {
    PENDING
    ACCEPTED
    DECLINED
    EXPIRED
}

enum FamilyRole {
    OWNER
    MEMBER
}

// Models
model User {
    id                 String              @id @default(uuid())
    accountId          String              @unique
    firstName          String
    lastName           String
    username           String              @unique
    displayName        String?
    email              String              @unique
    password           String
    phoneNumber        String?
    gender             UserGender
    birthDate          DateTime
    profilePicture     String?             @default("https://areawins.s3.us-east-2.amazonaws.com/common/user.jpg")
    location           String
    country            String
    state              String
    city               String
    skills             String[]
    role               UserRole            @default(USER)
    status             UserStatus          @default(ACTIVE)
    isIndependent      Boolean             @default(false)
    isEmailVerified    Boolean             @default(false)
    createdByOwner     String?
    owner              User?               @relation("OwnerCreatedUsers", fields: [createdByOwner], references: [id], onDelete: SetNull)
    createdUsers       User[]              @relation("OwnerCreatedUsers")
    contributionScore  Int                 @default(0)
    createdAt          DateTime            @default(now())
    updatedAt          DateTime            @updatedAt
    families           Family[]            @relation("FamilyCreator")
    familyMembers      FamilyMember[]
    familyInvitations  FamilyInvitation[]  @relation("FamilyInvitedBy")
    familyJoinRequests FamilyJoinRequest[] @relation("FamilyJoinRequest")

    @@index([createdByOwner])
    @@map("users")
}

// Category Model
model Category {
    id            String        @id @default(uuid())
    name          String        @unique
    imageUrl      String?
    description   String?
    isDeleted     Boolean       @default(false)
    createdAt     DateTime      @default(now())
    updatedAt     DateTime      @updatedAt
    subcategories Subcategory[]
    programs      Program[]

    @@map("categories")
}

// Create subcategory model with reference to category
model Subcategory {
    id          String    @id @default(uuid())
    categoryId  String
    name        String    @unique
    imageUrl    String?
    description String?
    isDeleted   Boolean   @default(false)
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt
    category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
    programs    Program[]

    @@index([categoryId])
    @@map("subcategories")
}

// Program model with reference category Or subcategory

model Program {
    id            String       @id @default(uuid())
    categoryId    String?
    subcategoryId String?
    name          String       @unique
    description   String?
    imageUrl      String?
    isDeleted     Boolean      @default(false)
    createdAt     DateTime     @default(now())
    updatedAt     DateTime     @updatedAt
    category      Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
    subcategory   Subcategory? @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)

    @@index([categoryId])
    @@index([subcategoryId])
    @@map("programs")
}

model Family {
    id                 String              @id @default(uuid())
    name               String
    description        String?
    imageUrl           String?
    createdBy          String
    creator            User                @relation("FamilyCreator", fields: [createdBy], references: [id], onDelete: Restrict)
    isDeleted          Boolean             @default(false)
    createdAt          DateTime            @default(now())
    updatedAt          DateTime            @updatedAt
    familyMembers      FamilyMember[]
    familyInvitations  FamilyInvitation[]
    familyJoinRequests FamilyJoinRequest[]

    @@index([createdBy])
    @@map("families")
}

model FamilyMember {
    id           String     @id @default(uuid())
    familyId     String
    userId       String
    role         FamilyRole @default(MEMBER)
    relationShip String?
    family       Family     @relation(fields: [familyId], references: [id], onDelete: Cascade)
    user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
    createdAt    DateTime   @default(now())
    updatedAt    DateTime   @updatedAt

    @@unique([familyId, userId])
    @@index([familyId])
    @@index([userId])
    @@map("family_members")
}

model FamilyInvitation {
    id              String           @id @default(uuid())
    familyId        String
    invitedByUserId String
    invitedEmail    String
    family          Family           @relation(fields: [familyId], references: [id], onDelete: Cascade)
    invitedByUser   User             @relation("FamilyInvitedBy", fields: [invitedByUserId], references: [id], onDelete: Cascade)
    status          InvitationStatus @default(PENDING)
    createdAt       DateTime         @default(now())
    updatedAt       DateTime         @updatedAt

    @@unique([familyId, invitedEmail])
    @@index([familyId])
    @@index([invitedByUserId])
    @@map("family_invitations")
}

model FamilyJoinRequest {
    id        String           @id @default(uuid())
    familyId  String
    userId    String
    family    Family           @relation(fields: [familyId], references: [id], onDelete: Cascade)
    user      User             @relation("FamilyJoinRequest", fields: [userId], references: [id], onDelete: Cascade)
    status    InvitationStatus @default(PENDING)
    createdAt DateTime         @default(now())
    updatedAt DateTime         @updatedAt

    @@unique([familyId, userId])
    @@index([familyId])
    @@index([userId])
    @@map("family_join_requests")
}
